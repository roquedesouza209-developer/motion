  "comments": [
    {
      "id": "cmt_501",
      "postId": "pst_101",
      "userId": "usr_ari",
      "text": "Those rooftop highlights are clean. The natural light really worked.",
      "createdAt": "2026-03-01T07:26:26.096Z"
    },
    {
      "id": "cmt_502",
      "postId": "pst_101",
      "userId": "usr_mina",
      "text": "Love the warmer grade on this set.",
      "createdAt": "2026-03-01T07:29:26.096Z"
    },
    {
      "id": "cmt_503",
      "postId": "pst_102",
      "userId": "usr_noah",
      "text": "That swipe timing is sharp. The pacing lands.",
      "createdAt": "2026-03-01T07:37:26.096Z"
    },
    {
      "id": "cmt_504",
      "postId": "pst_103",
      "userId": "usr_lena",
      "text": "The skin tones feel balanced without losing the street mood.",
      "createdAt": "2026-03-01T07:47:26.096Z"
    },
    {
      "id": "cmt_505",
      "postId": "pst_104",
      "userId": "usr_demo",
      "text": "The BTS framing is strong. The new lens profile looks crisp.",
